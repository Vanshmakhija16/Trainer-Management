generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Trainers — the core human asset. Conducts Events and is pitched to
// Organizations via the recruitment pipeline (Assignment).
// ---------------------------------------------------------------------------
model Trainer {
  id          String   @id @default(cuid())

  name        String
  firstName   String?
  lastName    String?
  email       String?  @unique
  phone       String?
  city        String?
  location    String?
  experience  Int?
  totalTrainingExperience Int?
  industryExperience      Int?
  linkedin    String?
  skills      String?
  primaryRole             String?
  areasOfExpertise        String[] @default([])
  detailedExpertise       String?
  trainingTypesDelivered  String[] @default([])
  availability            String[] @default([])
  expectedChargesPerDay   String?
  languages               String?
  declarationAccepted     Boolean @default(false)
  resumeUrl   String?
  photoUrl    String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments   Assignment[]
  eventTrainers EventTrainer[]
}

// ---------------------------------------------------------------------------
// Organization — generic client entity. Replaces the old University model.
// Covers universities, colleges, corporates, schools, NGOs, government,
// hospitals, etc. This is the spine of the CRM: every Event, Contact, and
// recruitment Assignment hangs off an Organization.
// ---------------------------------------------------------------------------
enum OrganizationType {
  UNIVERSITY
  COLLEGE
  CORPORATE
  SCHOOL
  NGO
  GOVERNMENT
  HOSPITAL
  OTHER
}

model Organization {
  id        String           @id @default(cuid())

  name      String
  type      OrganizationType @default(OTHER)
  website   String?
  industry  String?
  city      String?
  state     String?
  country   String?
  address   String?
  // Legacy free-text location from the University era; kept for back-compat
  // and migrated data. New records prefer city/state/country.
  location  String?
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())

  contacts    OrganizationContact[]
  events      Event[]
  assignments Assignment[]
}

// ---------------------------------------------------------------------------
// OrganizationContact — one org has many client-side contacts
// (Dean, HR, TPO, Wellness Manager, Faculty Coordinator, ...).
// ---------------------------------------------------------------------------
model OrganizationContact {
  id             String   @id @default(cuid())

  organizationId String
  name           String
  designation    String?
  phone          String?
  email          String?
  linkedin       String?
  notes          String?

  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// ---------------------------------------------------------------------------
// Event — the institutional memory record. One event belongs to one
// organization, can involve many trainers, and carries money, feedback,
// lead attribution, documents, and a timeline.
// ---------------------------------------------------------------------------
enum EventType {
  YOGA_SESSION
  WORKSHOP
  SEMINAR
  WEBINAR
  FDP
  TRAINING_PROGRAM
  INDUCTION_PROGRAM
  WELLNESS_SESSION
  CORPORATE_SESSION
  CONSULTING
  OTHER
}

enum EventStatus {
  PLANNED
  CONFIRMED
  COMPLETED
  CANCELLED
  POSTPONED
}

model Event {
  id                   String      @id @default(cuid())

  title                String
  eventType            EventType   @default(OTHER)
  organizationId       String
  description          String?

  // eventDate is the start date; endDate is set only for multi-day events.
  eventDate            DateTime?
  endDate              DateTime?
  startTime            String?
  endTime              String?
  venue                String?

  expectedParticipants Int?
  actualParticipants   Int?

  status               EventStatus @default(PLANNED)

  // Money. Decimal (not Float) to keep revenue arithmetic exact.
  // `profit` is derived (revenue - expenses) and written on save so it can be
  // aggregated directly in analytics queries.
  revenue              Decimal?    @db.Decimal(12, 2)
  expenses             Decimal?    @db.Decimal(12, 2)
  profit               Decimal?    @db.Decimal(12, 2)

  // Feedback
  feedbackRating       Float?
  clientFeedback       String?
  internalNotes        String?

  // Host — inlined rather than a separate model: a host is a single person
  // tied to one event and rarely reused/queried independently.
  hostName             String?
  hostPhone            String?
  hostEmail            String?

  // Lead attribution
  leadSource           String?
  leadOwner            String?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt @default(now())

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  trainers     EventTrainer[]
  documents    EventDocument[]
  activities   EventActivity[]

  @@index([organizationId])
  @@index([eventDate])
  @@index([status])
}

// ---------------------------------------------------------------------------
// EventTrainer — explicit M:N join between Event and Trainer. Explicit (not
// implicit) because the relationship carries data: the trainer's role on the
// event and their payout, which power trainer revenue/utilization analytics.
// ---------------------------------------------------------------------------
enum EventTrainerRole {
  LEAD
  CO_TRAINER
  ASSISTANT
  GUEST
}

model EventTrainer {
  id        String           @id @default(cuid())

  eventId   String
  trainerId String
  role      EventTrainerRole @default(LEAD)
  payout    Decimal?         @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  trainer Trainer @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@unique([eventId, trainerId])
  @@index([trainerId])
}

// ---------------------------------------------------------------------------
// EventDocument — files attached to an event (proposal, invoice, attendance
// sheet, photos, feedback report, completion report).
// ---------------------------------------------------------------------------
enum DocumentType {
  PROPOSAL
  INVOICE
  ATTENDANCE_SHEET
  PHOTO
  FEEDBACK_REPORT
  COMPLETION_REPORT
  OTHER
}

model EventDocument {
  id           String       @id @default(cuid())

  eventId      String
  fileName     String
  fileUrl      String
  documentType DocumentType @default(OTHER)

  uploadedAt   DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

// ---------------------------------------------------------------------------
// EventActivity — append-only timeline / audit trail for an event
// (lead received, proposal shared, confirmed, trainer assigned, completed).
// ---------------------------------------------------------------------------
enum ActivityType {
  LEAD_RECEIVED
  PROPOSAL_SHARED
  CONFIRMED
  TRAINER_ASSIGNED
  COMPLETED
  NOTE
  STATUS_CHANGE
  DOCUMENT_ADDED
  OTHER
}

model EventActivity {
  id           String       @id @default(cuid())

  eventId      String
  activityType ActivityType @default(NOTE)
  description  String?
  createdBy    String?

  createdAt    DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

// ---------------------------------------------------------------------------
// Assignment — existing recruitment pipeline (we pitch a Trainer to an
// Organization). Distinct from an Event (something that actually happened).
// Repointed from University to Organization.
// ---------------------------------------------------------------------------
enum AssignmentStatus {
  PENDING
  SENT
  INTERVIEW_SCHEDULED
  SELECTED
  REJECTED
  ON_HOLD
}

model Assignment {
  id             String           @id @default(cuid())

  trainerId      String
  organizationId String

  status         AssignmentStatus @default(PENDING)

  remarks        String?
  interviewDate  DateTime?

  createdAt      DateTime @default(now())

  trainer      Trainer      @relation(fields: [trainerId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([trainerId, organizationId])
}
