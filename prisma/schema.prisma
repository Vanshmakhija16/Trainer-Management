generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Trainers
// ---------------------------------------------------------------------------

enum TrainerType {
  YOGA
  CORPORATE
  WELLNESS
  FITNESS
  OTHER
}

model Trainer {
  id          String   @id @default(cuid())

  name        String
  firstName   String?
  lastName    String?
  email       String?  @unique
  phone       String?
  city        String?
  location    String?
  experience  Int?
  totalTrainingExperience Int?
  industryExperience      Int?
  linkedin    String?
  skills      String?
  primaryRole             String?
  areasOfExpertise        String[] @default([])
  detailedExpertise       String?
  trainingTypesDelivered  String[] @default([])
  availability            String[] @default([])
  expectedChargesPerDay   String?
  languages               String?
  declarationAccepted     Boolean @default(false)
  resumeUrl   String?
  photoUrl    String?

  trainerType   TrainerType @default(OTHER)

  yogaStyles      String[] @default([])
  certification   String?
  chargesPerDay   Int?

  onboardedYear   Int?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments   Assignment[]
  eventTrainers EventTrainer[]
}

// ---------------------------------------------------------------------------
// Organization
// ---------------------------------------------------------------------------
enum OrganizationType {
  UNIVERSITY
  COLLEGE
  CORPORATE
  SCHOOL
  NGO
  GOVERNMENT
  HOSPITAL
  OTHER
}

model Organization {
  id        String           @id @default(cuid())

  name      String
  type      OrganizationType @default(OTHER)
  website   String?
  industry  String?
  city      String?
  state     String?
  country   String?
  address   String?
  location  String?
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())

  contacts    OrganizationContact[]
  events      Event[]
  assignments Assignment[]
}

// ---------------------------------------------------------------------------
// OrganizationContact
// ---------------------------------------------------------------------------
model OrganizationContact {
  id             String   @id @default(cuid())

  organizationId String
  name           String
  designation    String?
  phone          String?
  email          String?
  linkedin       String?
  notes          String?

  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// ---------------------------------------------------------------------------
// Event
// ---------------------------------------------------------------------------
enum EventType {
  YOGA_SESSION
  WORKSHOP
  SEMINAR
  WEBINAR
  FDP
  TRAINING_PROGRAM
  INDUCTION_PROGRAM
  WELLNESS_SESSION
  CORPORATE_SESSION
  CONSULTING
  OTHER
}

enum EventStatus {
  PLANNED
  CONFIRMED
  COMPLETED
  CANCELLED
  POSTPONED
}

model Event {
  id                   String      @id @default(cuid())

  title                String
  eventType            EventType   @default(OTHER)
  organizationId       String
  description          String?

  eventDate            DateTime?
  endDate              DateTime?
  startTime            String?
  endTime              String?
  venue                String?

  // ── Session fields (from IYD sheet) ──────────────────────────────────────
  noOfSessions         Int?                        // Total number of sessions
  sessionCharges       Decimal?    @db.Decimal(12, 2) // Per-session charge (₹)
  // totalCharges is derived: noOfSessions * sessionCharges — use revenue field
  // ─────────────────────────────────────────────────────────────────────────

  expectedParticipants Int?
  actualParticipants   Int?

  status               EventStatus @default(PLANNED)

  revenue              Decimal?    @db.Decimal(12, 2)
  expenses             Decimal?    @db.Decimal(12, 2)
  profit               Decimal?    @db.Decimal(12, 2)

  feedbackRating       Float?
  clientFeedback       String?
  internalNotes        String?

  hostName             String?
  hostPhone            String?
  hostEmail            String?

  leadSource           String?
  leadOwner            String?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt @default(now())

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  trainers     EventTrainer[]
  documents    EventDocument[]
  activities   EventActivity[]

  @@index([organizationId])
  @@index([eventDate])
  @@index([status])
}

// ---------------------------------------------------------------------------
// EventTrainer
// ---------------------------------------------------------------------------
enum EventTrainerRole {
  LEAD
  CO_TRAINER
  ASSISTANT
  GUEST
}

model EventTrainer {
  id        String           @id @default(cuid())

  eventId   String
  trainerId String
  role      EventTrainerRole @default(LEAD)
  payout    Decimal?         @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  trainer Trainer @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@unique([eventId, trainerId])
  @@index([trainerId])
}

// ---------------------------------------------------------------------------
// EventDocument
// ---------------------------------------------------------------------------
enum DocumentType {
  PROPOSAL
  INVOICE
  ATTENDANCE_SHEET
  PHOTO
  FEEDBACK_REPORT
  COMPLETION_REPORT
  OTHER
}

model EventDocument {
  id           String       @id @default(cuid())

  eventId      String
  fileName     String
  fileUrl      String
  documentType DocumentType @default(OTHER)

  uploadedAt   DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

// ---------------------------------------------------------------------------
// EventActivity
// ---------------------------------------------------------------------------
enum ActivityType {
  LEAD_RECEIVED
  PROPOSAL_SHARED
  CONFIRMED
  TRAINER_ASSIGNED
  COMPLETED
  NOTE
  STATUS_CHANGE
  DOCUMENT_ADDED
  OTHER
}

model EventActivity {
  id           String       @id @default(cuid())

  eventId      String
  activityType ActivityType @default(NOTE)
  description  String?
  createdBy    String?

  createdAt    DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

// ---------------------------------------------------------------------------
// Assignment
// ---------------------------------------------------------------------------
enum AssignmentStatus {
  PENDING
  SENT
  INTERVIEW_SCHEDULED
  SELECTED
  REJECTED
  ON_HOLD
}

model Assignment {
  id             String           @id @default(cuid())

  trainerId      String
  organizationId String

  status         AssignmentStatus @default(PENDING)

  remarks        String?
  interviewDate  DateTime?

  createdAt      DateTime @default(now())

  trainer      Trainer      @relation(fields: [trainerId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([trainerId, organizationId])
}
